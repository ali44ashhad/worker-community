{
  "installCommand": "rm -rf node_modules && npm install --include=optional",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://api.commun.in/api/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://api.commun.in/api/robots.txt"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://api.commun.in/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}