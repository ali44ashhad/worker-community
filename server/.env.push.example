# Web Push for browser / PWA
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@commun.in

# React Native / native mobile push via Firebase Admin
# Android uses FCM directly.
# iOS also uses FCM token from the app; Firebase routes to APNs.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional mobile push metadata
FCM_ANDROID_CHANNEL_ID=default
